{
  "lock": false,
  "tasks": {
    "build": "deno run -A ../client/_build.ts --out-dir ./web/runtime",
    "watch": "deno run -A ../client/_build.ts --out-dir ./web/runtime --watch --serve-port 5181",
    "build-world": "deno run -A ./_build-world.ts",
    "build-single-file": "deno run -A ./_build-bundled.ts",
    "package": "deno run -A ./_package.ts"
  },
  "imports": {
    "@dreamlab/engine": "../engine/mod.ts",
    "@dreamlab/engine/internal": "../engine/internal.ts",
    "@dreamlab/vendor/": "../engine/_deps/",
    "@dreamlab/proto/": "../proto/",
    "@dreamlab/scene": "../scene-graph/mod.ts",
    "@dreamlab/ui": "../ui/mod.ts",
    "@dreamlab/util/": "../util/",
    "env": "data:application/javascript,export default {}"
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom"]
  },
  "exclude": ["./web/runtime/*"],
  "lint": {
    "rules": {
      "exclude": ["no-window"]
    }
  }
}
