{
  "tasks": {
    "dev": "deno run --watch _main.ts",
    "web:build": "deno run -A _web/_build.ts",
    "web:dev": "deno run -A _web/_build.ts --dev",
    "web:serve": "deno run -A jsr:@std/http@0.224.0/file-server --port 3000 ./_web/www"
  },
  "imports": {
    "@rebur/engine": "./mod.ts",
    "@rebur/engine/internal": "./internal.ts",
    "@rebur/vendor/": "./_deps/",
    "@rebur/ui": "../ui/mod.ts",
    "@rebur/util/": "../util/"
  },
  "lint": {
    "rules": {
      "exclude": ["no-this-alias", "no-import-prefix"]
    }
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom"],
    "noImplicitOverride": false
  }
}
